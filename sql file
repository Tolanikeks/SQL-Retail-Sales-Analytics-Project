-- How much revenue was lost through refunds?
SELECT
    COUNT(CASE WHEN payment_status = 'Refunded' THEN 1 END) AS refunded_orders,
    SUM(CASE WHEN payment_status = 'Refunded' THEN total_amount ELSE 0 END) AS refund_amount,
    ROUND(
        100.0 * COUNT(CASE WHEN payment_status = 'Refunded' THEN 1 END)
        / COUNT(*),
        2
    ) AS refund_percentage
FROM orders;


-- How many customers returned after their first purchase?
WITH customer_orders AS
(
    SELECT
        customer_id,
        COUNT(order_id) AS total_orders
    FROM orders
    GROUP BY customer_id
)

SELECT
    COUNT(*) AS returning_customers
FROM customer_orders
WHERE total_orders > 1;


